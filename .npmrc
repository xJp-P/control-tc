# No instalar dependencias OPCIONALES.
# Motivo: pdfjs-dist v3 arrastra `canvas` como optionalDependency, que NO usamos (solo
# extraemos texto, no renderizamos). En el runner de Windows, electron-builder intenta
# recompilar `canvas` con node-gyp y falla porque Python 3.12 ya no incluye `distutils`.
# Omitiendo las opcionales, canvas no se instala y el build pasa en todas las plataformas.
omit=optional
